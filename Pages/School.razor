            },
            ("Michael Lee", "12") => new()
            {
                new() { Period=1, ClassName="AP Calculus BC",       TeacherName="Dr. Singh"  },
                new() { Period=2, ClassName="AP Literature",        TeacherName="Ms. Evans"  },
