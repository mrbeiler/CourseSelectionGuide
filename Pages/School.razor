                new() { Period=5, ClassName="Lunch / Study Hall", TeacherName="—"            },
                new() { Period=6, ClassName="Spanish II",         TeacherName="Señora Gomez" },
                new() { Period=7, ClassName="Physical Education", TeacherName="Coach Davis"  },
                new() { Period=8, ClassName="Art Studio",         TeacherName="Ms. Chen"     },
                new() { Period=9, ClassName="Computer Science",   TeacherName="Mr. Nguyen"   },
            },
            ("John Smith", "11") => new()
            {
                new() { Period=1, ClassName="Pre-Calculus",       TeacherName="Ms. Huang"   },
                new() { Period=2, ClassName="AP English Lang",    TeacherName="Mr. Wallace" },
                new() { Period=3, ClassName="US History",         TeacherName="Mr. O'Brien" },
                new() { Period=4, ClassName="Chemistry",          TeacherName="Dr. Kim"     },
                new() { Period=5, ClassName="Lunch / Study Hall", TeacherName="—"           },
                new() { Period=6, ClassName="French III",         TeacherName="Mme. Dubois" },
                new() { Period=7, ClassName="Orchestra",          TeacherName="Mr. Russo"   },
                new() { Period=8, ClassName="Photography",        TeacherName="Ms. Alvarez" },
                new() { Period=9, ClassName="AP Psychology",      TeacherName="Dr. Freeman" },
            },
            ("Emily Clark", "9") => new()
            {
                new() { Period=1, ClassName="Geometry",              TeacherName="Ms. Brooks"   },
                new() { Period=2, ClassName="English 9",             TeacherName="Mr. Jensen"   },
                new() { Period=3, ClassName="Ancient Civilizations", TeacherName="Ms. Grant"    },
                new() { Period=4, ClassName="Earth Science",         TeacherName="Mr. Flores"   },
                new() { Period=5, ClassName="Lunch / Study Hall",    TeacherName="—"            },
                new() { Period=6, ClassName="Spanish I",             TeacherName="Señor Medina" },
                new() { Period=7, ClassName="Physical Education",    TeacherName="Coach Davis"  },
                new() { Period=8, ClassName="Drama",                 TeacherName="Ms. Park"     },
