@page "/courselist"
@using CourseSelectionGuide.Models
@layout Header 
@inject ClassListService ClassListService

<style>
    .course-catalog {
        padding: 30px;
        max-width: 1200px;
        margin: 0 auto;
    }

    .page-header {
        margin-bottom: 40px;
    }

    .page-title {
        font-size: 2rem;
        font-weight: 600;
        color: #333;
        margin-bottom: 8px;
    }

    .page-subtitle {
        color: #666;
        font-size: 1rem;
    }

    .dept-section {
        margin-bottom: 24px;
        border: 1px solid #ddd;
        border-radius: 8px;
        overflow: hidden;
    }

    .dept-header {
        background: #2d4a32;
        color: white;
        padding: 16px 20px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: space-between;
        outline: none;
    }

    .dept-header:hover {
        background: #3d6645;
    }

    .dept-header:focus {
        outline: none;
    }

    .dept-title {
        font-size: 1.2rem;
        font-weight: 600;
        margin: 0;
    }

    .dept-count {
        background: rgba(255, 255, 255, 0.2);
        padding: 4px 10px;
        border-radius: 4px;
        font-size: 0.9rem;
    }

    .dept-body {
        background: white;
        padding: 20px;
    }

    .course-grid {
        display: grid;
        gap: 16px;
    }

    .course-card {
        background: #f9f9f9;
        border: 1px solid #e0e0e0;
        border-radius: 6px;
        padding: 18px;
    }

    .course-header {
        display: flex;
        justify-content: space-between;
        align-items: start;
        margin-bottom: 12px;
        gap: 12px;
    }

    .course-name {
        font-size: 1.1rem;
        font-weight: 600;
        color: #2d4a32;
        margin: 0;
    }

    .course-badges {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        flex-shrink: 0;
    }

    .badge-custom {
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 500;
        white-space: nowrap;
    }

    .badge-credits {
        background: #e3f2fd;
        color: #1976d2;
    }

    .badge-required {
        background: #fff3e0;
        color: #f57c00;
    }

    .badge-grade {
        background: #f3e5f5;
        color: #7b1fa2;
    }

    .course-description {
        color: #555;
        line-height: 1.5;
        margin-bottom: 12px;
        font-size: 0.95rem;
    }

    .course-details {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        padding-top: 10px;
        border-top: 1px solid #ddd;
        font-size: 0.85rem;
    }

    .detail-item {
        color: #666;
    }

    .detail-label {
        font-weight: 600;
        color: #333;
    }

    .collapse {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease;
    }

    .collapse.show {
        max-height: 5000px;
    }

    .chevron {
        font-size: 1.2rem;
        font-weight: bold;
    }

    .loading {
        text-align: center;
        padding: 60px;
        color: #666;
        font-size: 1.1rem;
    }
</style>

<div class="course-catalog">
    <div class="page-header">
        <h1 class="page-title">Course Catalog</h1>
        <p class="page-subtitle">Browse all available courses by department</p>
    </div>

    @if (isLoading)
    {
        <div class="loading">Loading courses...</div>
    }
    else if (coursesByDepartment.Count == 0)
    {
        <div class="loading">No courses available.</div>
    }
    else
    {
        @foreach (var dept in coursesByDepartment.OrderBy(d => d.Key))
        {
            var deptId = $"dept-{dept.Key.Replace(" ", "-")}";
            var isExpanded = expandedDepartments.Contains(dept.Key);

            <div class="dept-section">
                <div class="dept-header" @onclick="() => ToggleDepartment(dept.Key)">
                    <div class="dept-title">
                        <span>@dept.Key</span>
                    </div>
                    <div style="display: flex; align-items: center; gap: 12px;">
                        <span class="dept-count">@dept.Value.Count courses</span>
                        <span class="chevron">@(isExpanded ? "-" : "+")</span>
                    </div>
                </div>
                <div class="collapse @(isExpanded ? "show" : "")">
                    <div class="dept-body">
                        <div class="course-grid">
                            @foreach (var course in dept.Value.OrderBy(c => c.Name))
                            {
                                <div class="course-card">
                                    <div class="course-header">
                                        <h3 class="course-name">@course.Name</h3>
                                        <div class="course-badges">
                                            <span class="badge-custom badge-credits">@course.Credits cr</span>
                                            @if (course.IsRequired)
                                            {
                                                <span class="badge-custom badge-required">Required</span>
                                            }
                                            @if (!string.IsNullOrEmpty(GetGradeRange(course)))
                                            {
                                                <span class="badge-custom badge-grade">@GetGradeRange(course)</span>
                                            }
                                        </div>
                                    </div>
                                    <p class="course-description">@course.Description</p>
                                    <div class="course-details">
                                        @if (!string.IsNullOrEmpty(course.Prerequisite))
                                        {
                                            <div class="detail-item">
                                                <span class="detail-label">Prerequisite:</span>
                                                <span>@course.Prerequisite</span>
                                            </div>
                                        }
                                        @if (!string.IsNullOrEmpty(course.CreditType))
                                        {
                                            <div class="detail-item">
                                                <span class="detail-label">Credit Type:</span>
                                                <span>@course.CreditType</span>
                                            </div>
                                        }
                                        @if (!string.IsNullOrEmpty(course.Notes))
                                        {
                                            <div class="detail-item">
                                                <span class="detail-label">Notes:</span>
                                                <span>@course.Notes</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<Course> allCourses = new();
    private Dictionary<string, List<Course>> coursesByDepartment = new();
    private HashSet<string> expandedDepartments = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            allCourses = await ClassListService.GetClassesAsync();

            coursesByDepartment = allCourses
                .Where(c => !string.IsNullOrEmpty(c.Department))
                .GroupBy(c => c.Department)
                .ToDictionary(g => g.Key, g => g.ToList());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading courses: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ToggleDepartment(string department)
    {
        if (expandedDepartments.Contains(department))
        {
            expandedDepartments.Remove(department);
        }
        else
        {
            expandedDepartments.Add(department);
        }
    }

    private string GetGradeRange(Course course)
    {
        if (course.GradeMin == course.GradeMax)
        {
            return $"Grade {course.GradeMin}";
        }
        else if (course.GradeMin > 0 && course.GradeMax > 0)
        {
            return $"Grades {course.GradeMin}-{course.GradeMax}";
        }
        return "";
    }
}
