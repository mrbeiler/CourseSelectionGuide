                new() { Period=4, ClassName="AP Physics C",         TeacherName="Dr. Okafor" },
                new() { Period=5, ClassName="Lunch / Study Hall",   TeacherName="—"          },
                new() { Period=6, ClassName="Mandarin IV",          TeacherName="Ms. Zhou"   },
                new() { Period=7, ClassName="Robotics Club",        TeacherName="Mr. Nguyen" },
                new() { Period=8, ClassName="Senior Seminar",       TeacherName="Ms. Rivera" },
                new() { Period=9, ClassName="AP Statistics",        TeacherName="Mr. Carter" },
            },
            _ => new()  // no schedule on file
        };
    }
}

