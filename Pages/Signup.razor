@page "/signup"
@layout LoginLayout
@inject UserSession UserSession
@inject SupabaseService SupabaseService
@inject SessionStorageService Storage
@inject NavigationManager Nav

<div class="login-container">
    <div class="login-card">

        <!-- Left side -->
        <div class="login-left">
            <img src="faith.png" alt="School Logo" class="logo" />
            <h2>Faith Christian School</h2>
            <p>"Romans 10:17"</p>
            <span class="subtitle">Course Selection Guide</span>
        </div>

        <!-- Right side -->
        <div class="login-right">
            <h3>Create Account</h3>

            <EditForm Model="@signupModel" OnValidSubmit="@HandleSignup">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="form-group">
                    <label>Full Name</label>
                    <InputText class="form-control" @bind-Value="signupModel.Name" />
                </div>

                <div class="form-group">
                    <label>Email</label>
                    <InputText class="form-control" @bind-Value="signupModel.Email" />
                </div>

                <div class="form-group">
                    <label>Password</label>
                    <InputText type="password" class="form-control" @bind-Value="signupModel.Password" />
                </div>

                <div class="form-group">
                    <label>Grade</label>
                    <InputSelect class="form-control" @bind-Value="signupModel.Grade">
                        <option value="">Select Grade</option>
                        <option value="9">9th Grade</option>
                        <option value="10">10th Grade</option>
                        <option value="11">11th Grade</option>
                        <option value="12">12th Grade</option>
                    </InputSelect>
                </div>

                <button class="btn-login" type="submit">Sign Up</button>

                @if (!string.IsNullOrEmpty(message))
                {
                    <p class="@(isError ? "text-danger" : "text-success")">@message</p>
                }

                <p style="margin-top: 15px; text-align: center; font-size: 0.9rem;">
                    Already have an account? <a href="/" style="color: #7fbf3f; text-decoration: none;">Sign In</a>
                </p>
            </EditForm>
        </div>

    </div>
</div>

@code {
    private SignupModel signupModel = new();
    private string message = "";
    private bool isError = false;

    private async Task HandleSignup()
    {
        // Validate required fields
        if (string.IsNullOrWhiteSpace(signupModel.Name) ||
            string.IsNullOrWhiteSpace(signupModel.Email) ||
            string.IsNullOrWhiteSpace(signupModel.Password) ||
            string.IsNullOrWhiteSpace(signupModel.Grade))
        {
            message = "All fields are required.";
            isError = true;
            return;
        }

        var user = await SupabaseService.Signup(
            signupModel.Name,
            signupModel.Email,
            signupModel.Password,
            signupModel.Grade
        );

        if (user != null)
        {
            UserSession.UserId = user.Id;
            UserSession.Name = user.Name;
            UserSession.Grade = user.Grade;

            await Storage.SaveAsync(UserSession);
            Nav.NavigateTo("courseselection");
        }
        else
        {
            message = "Email already exists or signup failed.";
            isError = true;
        }
    }

    public class SignupModel
    {
        public string Name { get; set; } = "";
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
        public string Grade { get; set; } = "";
    }
}
